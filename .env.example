# Core local service
WEBOT_API_KEY=yoko_test
YOKO_MCP_TOKEN=

# Original/cloud build only. The unlocked source does not require these for licensing.
YOKO_API_BASE=http://127.0.0.1:3000
SUPABASE_URL=http://127.0.0.1:8000
SUPABASE_KEY=

# Optional alert email
YOKO_ALERT_EMAIL_ADDRESS=
YOKO_ALERT_EMAIL_PASSWORD=
YOKO_ALERT_EMAIL_RECEIVER=
YOKO_ALERT_SMTP_SERVER=smtp.qq.com
YOKO_ALERT_SMTP_PORT=465

# Optional customer A integration
CUSTOMER_A_ID=CUSTOMER_A
CUSTOMER_A_NAME=Customer A
CUSTOMER_A_BASE_URL=
CUSTOMER_A_TOKEN=
CUSTOMER_A_AUTH_HEADER=token
CUSTOMER_A_GET_FRIENDS_PATH=/friends
CUSTOMER_A_ADD_FRIEND_PATH=/friends/add

# Optional customer B integration
CUSTOMER_B_ID=CUSTOMER_B
CUSTOMER_B_NAME=Customer B
CUSTOMER_B_BASE_URL=
CUSTOMER_B_API_KEY=
CUSTOMER_B_AUTH_HEADER=Authorization
CUSTOMER_B_GET_FRIENDS_PATH=/friends
CUSTOMER_B_ADD_FRIEND_PATH=/friends/add
